# ==================================
# Therex 环境变量配置
# ==================================
# 复制此文件为 .env.local 并填入实际值

# ==================================
# Supabase 数据库配置（可选）
# ==================================
# 在 https://supabase.com 创建项目后获取
# 用于云端数据同步
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 服务端使用的密钥（可在 Supabase Dashboard > Settings > API 中找到）
SUPABASE_SERVICE_ROLE_KEY=

# ==================================
# AI 服务配置（可选）
# ==================================
# 默认 AI 提供商: doubao, deepseek, openai, kimi, custom
AI_DEFAULT_MODEL=doubao

# AI API 端点（不同提供商的端点不同）
# 豆包: https://ark.cn-beijing.volces.com/api/v3
# DeepSeek: https://api.deepseek.com/v1
# OpenAI: https://api.openai.com/v1
# Kimi: https://api.moonshot.cn/v1
AI_API_ENDPOINT=

# AI API 密钥（也可以在前端设置页面配置）
AI_API_KEY=

# ==================================
# 应用配置
# ==================================
# 应用 URL（用于生成绝对链接）
NEXT_PUBLIC_APP_URL=http://localhost:5000

# 应用名称
NEXT_PUBLIC_APP_NAME=Therex

# 应用环境: development, production
NODE_ENV=development

# ==================================
# 错误监控（可选）
# ==================================
# Sentry DSN（用于错误监控和性能追踪）
NEXT_PUBLIC_SENTRY_DSN=

# Sentry 认证令牌（用于上传 Source Map）
SENTRY_AUTH_TOKEN=

# ==================================
# 分析工具（可选）
# ==================================
# Google Analytics ID
NEXT_PUBLIC_GA_ID=

# ==================================
# 日志配置
# ==================================
# 日志级别: debug, info, warn, error
LOG_LEVEL=info
