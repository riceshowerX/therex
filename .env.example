# ==================================
# MarkFlow 环境变量配置
# ==================================
# 复制此文件为 .env.local 并填入实际值

# ==================================
# Supabase 数据库配置（必需）
# ==================================
# 在 https://supabase.com 创建项目后获取
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# 服务端使用的密钥（可在 Supabase Dashboard > Settings > API 中找到）
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==================================
# AI 服务配置（可选）
# ==================================
# 默认 AI 提供商: doubao, deepseek, openai, kimi, custom
AI_DEFAULT_MODEL=doubao

# AI API 端点（不同提供商的端点不同）
# 豆包: https://ark.cn-beijing.volces.com/api/v3
# DeepSeek: https://api.deepseek.com/v1
# OpenAI: https://api.openai.com/v1
# Kimi: https://api.moonshot.cn/v1
AI_API_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3

# AI API 密钥（也可以在前端设置页面配置）
AI_API_KEY=your_ai_api_key

# ==================================
# 应用配置
# ==================================
# 应用 URL（用于生成分享链接等）
NEXT_PUBLIC_APP_URL=http://localhost:5000

# 应用名称
NEXT_PUBLIC_APP_NAME=MarkFlow

# ==================================
# 错误监控（可选）
# ==================================
# Sentry DSN（用于错误监控）
NEXT_PUBLIC_SENTRY_DSN=

# Sentry 认证令牌（用于上传 Source Map）
SENTRY_AUTH_TOKEN=

# ==================================
# 对象存储（可选）
# ==================================
# AWS S3 或兼容服务配置
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=markflow-uploads

# ==================================
# 分析工具（可选）
# ==================================
# Google Analytics ID
NEXT_PUBLIC_GA_ID=

# ==================================
# 开发配置
# ==================================
# Node 环境: development, production
NODE_ENV=development

# 日志级别: debug, info, warn, error
LOG_LEVEL=debug
